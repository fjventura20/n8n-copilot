{
  "name": "n8n Co Pilot",
  "version": "1.0",
  "description": "AI assistant for building n8n workflows",
  "manifest_version": 3,
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_popup": "action/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "options_page": "action/settings/settings.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "chatbot/chatbot.js",
        "chatbot/chatbot.css",
        "chatbot/chatbot.html",
        "assets/icons/chat-icon-48.png",
        "action/styles.css",
        "action/settings/settings.css",
        "chatbot/modules/chatbot-ui.js",
        "chatbot/modules/chatbot-api.js",
        "chatbot/modules/chatbot-workflow.js",
        "chatbot/modules/chatbot-openai.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}