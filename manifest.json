{
  "name": "n8n Co Pilot",
  "version": "1.0",
  "description": "AI assistant for building n8n workflows",
  "manifest_version": 3,
  "icons": {
    "16": "action/icons/icon16.png",
    "48": "action/icons/icon48.png",
    "128": "action/icons/icon128.png"
  },
  "action": {
    "default_popup": "action/popup.html",
    "default_icon": {
      "16": "action/icons/icon16.png",
      "48": "action/icons/icon48.png",
      "128": "action/icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "options_page": "action/settings/settings.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dom/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "chatbot/chatbot.js",
        "chatbot/chatbot.css",
        "chatbot/chatbot.html",
        "action/icons/chat-icon-48.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}